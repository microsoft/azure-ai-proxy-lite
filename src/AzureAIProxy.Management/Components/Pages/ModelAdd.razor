@page "/models/new"
@namespace AzureAIProxy.Management.Components.Pages
@using AzureAIProxy.Management.Components.ModelManagement

<MudStack>
    <Help Title="Create a new resource" Link="https://microsoft.github.io/azure-ai-proxy-lite/resources/" />

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <MudAlert Severity="Severity.Error" ShowCloseIcon="true" CloseIconClicked="() => ErrorMessage = null">@ErrorMessage</MudAlert>
    }

    <ModelEditor OnValidSubmit="@HandleValidSubmit" />
</MudStack>
