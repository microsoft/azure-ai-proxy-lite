@page "/models/{id}"

@namespace AzureAIProxy.Management.Components.Pages
@using AzureAIProxy.Management.Components.ModelManagement

<MudStack>
    <Help Title="Edit model registration" Link="https://microsoft.github.io/azure-ai-proxy-lite/resources/" />

    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <MudAlert Severity="Severity.Error" ShowCloseIcon="true" CloseIconClicked="() => ErrorMessage = null">@ErrorMessage</MudAlert>
    }

    <ModelEditor OnValidSubmit="@OnValidSubmit" @bind-Model="Model" />
</MudStack>
